{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and wallet balance",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "balance", "role"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "User's electric vehicle",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "model": { "type": "string" },
        "batteryCapacity": { "type": "number" },
        "currentBattery": { "type": "number" },
        "plugType": { "type": "string" },
        "plate": { "type": "string" }
      },
      "required": ["userId", "model", "batteryCapacity", "currentBattery", "plugType"]
    },
    "Station": {
      "title": "Station",
      "description": "Charging station details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "network": { "type": "string" },
        "connectors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "power": { "type": "string" },
              "available": { "type": "boolean" },
              "price": { "type": "number" }
            },
            "required": ["type", "power", "available", "price"]
          }
        }
      },
      "required": ["name", "address", "lat", "lng", "network", "connectors"]
    },
    "Session": {
      "title": "Session",
      "description": "Active or completed charging session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "stationId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "kwhAdded": { "type": "number" },
        "currentPower": { "type": "number" },
        "cost": { "type": "number" },
        "batteryStart": { "type": "number" },
        "batteryCurrent": { "type": "number" }
      },
      "required": ["userId", "stationId", "startTime", "status", "kwhAdded", "currentPower", "cost", "batteryStart", "batteryCurrent"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["charge", "deposit"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "title": { "type": "string" }
      },
      "required": ["userId", "type", "amount", "date", "title"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/vehicles/{vehicleId}": {
      "schema": { "$ref": "#/entities/Vehicle" },
      "description": "User vehicles"
    },
    "/stations/{stationId}": {
      "schema": { "$ref": "#/entities/Station" },
      "description": "Charging stations"
    },
    "/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/Session" },
      "description": "Charging sessions"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Wallet transactions"
    }
  }
}
